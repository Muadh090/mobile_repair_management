<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Team Kanban View -->
    <record id="view_repair_team_kanban" model="ir.ui.view">
        <field name="name">repair.team.kanban</field>
        <field name="model">repair.team</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="manager_id"/>
                <field name="member_ids"/>
                <field name="completed_jobs"/>
                <field name="avg_repair_time"/>
                <field name="color"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record_has_image_fill" t-att-style="'border-left: 4px solid ' + kanban_color(record.color.raw_value)">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="text-muted" style="font-size:13px;">
                                    Manager: <field name="manager_id"/>
                                </div>
                                <div style="margin-top:8px;display:flex;gap:16px;">
                                    <div>
                                        <span class="text-muted" style="font-size:11px;">Members</span><br/>
                                        <strong><t t-esc="record.member_ids.raw_value.length"/></strong>
                                    </div>
                                    <div>
                                        <span class="text-muted" style="font-size:11px;">Completed</span><br/>
                                        <strong><field name="completed_jobs"/></strong>
                                    </div>
                                    <div>
                                        <span class="text-muted" style="font-size:11px;">Avg Time</span><br/>
                                        <strong><field name="avg_repair_time" widget="float_time"/></strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Team List View -->
    <record id="view_repair_team_tree" model="ir.ui.view">
        <field name="name">repair.team.list</field>
        <field name="model">repair.team</field>
        <field name="arch" type="xml">
            <list string="Teams">
                <field name="name"/>
                <field name="manager_id"/>
                <field name="completed_jobs"/>
                <field name="avg_repair_time" widget="float_time"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Team Form View -->
    <record id="view_repair_team_form" model="ir.ui.view">
        <field name="name">repair.team.form</field>
        <field name="model">repair.team</field>
        <field name="arch" type="xml">
            <form string="Team">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="manager_id" required="1"/>
                            <field name="project_id"/>
                            <field name="color" widget="color"/>
                        </group>
                        <group>
                            <field name="completed_jobs" readonly="1"/>
                            <field name="avg_repair_time" widget="float_time" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Members">
                            <field name="member_ids" widget="many2many" nolabel="1">
                                <list>
                                    <field name="name"/>
                                    <field name="email"/>
                                </list>
                            </field>
                        </page>
                        <page string="Description">
                            <field name="description" widget="html"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Team Action -->
    <record id="action_repair_team" model="ir.actions.act_window">
        <field name="name">Teams</field>
        <field name="res_model">repair.team</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="groups_id" eval="[(6, 0, [
            ref('mobile_repair_management.group_repair_manager'),
            ref('mobile_repair_management.group_repair_lead'),
        ])]"/>
    </record>
</odoo>