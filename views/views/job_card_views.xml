<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Job Card Kanban View -->
    <record id="view_job_card_kanban" model="ir.ui.view">
        <field name="name">job.card.kanban</field>
        <field name="model">job.card</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="state"/>
                <field name="customer_id"/>
                <field name="team_id"/>
                <field name="total_amount"/>
                <field name="currency_id"/>
                <field name="create_date"/>
                <templates>
                    <t t-name="kanban-box">
                        <t t-set="state_val" t-value="record.state.raw_value"/>
                        <t t-set="card_color_map" t-value="{
                            draft: 'linear-gradient(135deg, #f6f7fb 0%, #e7ebf6 100%)',
                            requested: 'linear-gradient(135deg, #e3f2ff 0%, #c8e3ff 100%)',
                            quotation: 'linear-gradient(135deg, #fff0d8 0%, #ffd69f 100%)',
                            approved: 'linear-gradient(135deg, #e8fff2 0%, #c9f4da 100%)',
                            in_progress: 'linear-gradient(135deg, #e5edff 0%, #c7d6ff 100%)',
                            completed: 'linear-gradient(135deg, #e5f8ef 0%, #c8eedc 100%)',
                            rejected: 'linear-gradient(135deg, #ffe6e6 0%, #ffb8b8 100%)',
                        }"/>
                        <t t-set="accent_map" t-value="{
                            draft: '#4b5563',
                            requested: '#1d4ed8',
                            quotation: '#c2410c',
                            approved: '#15803d',
                            in_progress: '#1e3a8a',
                            completed: '#0f766e',
                            rejected: '#b91c1c',
                        }"/>
                        <t t-set="card_color" t-value="card_color_map[state_val] || card_color_map.draft"/>
                        <t t-set="accent" t-value="accent_map[state_val] || accent_map.requested"/>
                        <div class="oe_kanban_global_click" t-att-style="'background:' + card_color + ';border-left:6px solid ' + accent + ';box-shadow:0 8px 18px rgba(0,0,0,0.12);padding:14px;border-radius:12px;'">
                            <div class="o_kanban_record_top" style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title" t-att-style="'color:' + accent + ';'">
                                        <field name="name"/>
                                    </strong>
                                    <div class="text-muted" style="font-size:13px;">
                                        <field name="customer_id"/>
                                    </div>
                                </div>
                                <div class="oe_kanban_bottom_left">
                                    <field name="state" widget="badge"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom" style="display:flex;justify-content:space-between;align-items:center;margin-top:10px;gap:8px;">
                                <div class="text-muted" style="font-size:12px;">Team: <field name="team_id"/></div>
                                <div style="font-weight:600;color:#111;">
                                    <field name="total_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Job Card List View -->
    <record id="view_job_card_tree" model="ir.ui.view">
        <field name="name">job.card.list</field>
        <field name="model">job.card</field>
        <field name="arch" type="xml">
            <list string="Job Cards">
                <field name="name" string="Job Card No."/>
                <field name="state" widget="badge"/>
                <field name="customer_id"/>
                <field name="brand_id"/>
                <field name="model_id"/>
                <field name="team_id"/>
                <field name="total_amount" sum="Total Amount"/>
                <field name="invoice_status"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- Job Card Form View -->
    <record id="view_job_card_form" model="ir.ui.view">
        <field name="name">job.card.form</field>
        <field name="model">job.card</field>
        <field name="arch" type="xml">
            <form string="Job Card">
                <field name="currency_id" invisible="1"/>
                <header>
                    <button name="action_mark_requested" string="Mark Requested" type="object" class="btn-primary" invisible="state != 'draft'" groups="mobile_repair_management.group_repair_manager,mobile_repair_management.group_repair_lead,mobile_repair_management.group_repair_csr"/>
                    <button name="action_generate_quotation" string="Generate Quotation" type="object" class="btn-secondary" invisible="warranty or state in ('in_progress', 'completed', 'rejected')" groups="mobile_repair_management.group_repair_manager,mobile_repair_management.group_repair_lead,mobile_repair_management.group_repair_csr"/>
                    <button name="action_customer_approve" string="Customer Approve" type="object" class="btn-primary" invisible="state != 'quotation'" groups="mobile_repair_management.group_repair_manager,mobile_repair_management.group_repair_lead,mobile_repair_management.group_repair_csr"/>
                    <button name="action_customer_reject" string="Customer Reject" type="object" class="btn-danger" invisible="state != 'quotation'" groups="mobile_repair_management.group_repair_manager,mobile_repair_management.group_repair_lead,mobile_repair_management.group_repair_csr"/>
                    <button name="action_create_invoice" string="Create Invoice" type="object" class="btn-primary" invisible="warranty or invoice_id or state in ('in_progress', 'completed', 'rejected')" groups="mobile_repair_management.group_repair_manager,mobile_repair_management.group_repair_lead,mobile_repair_management.group_repair_accounting"/>
                    <button name="action_assign_team" string="Assign Team" type="object" class="btn-primary" invisible="state in ('in_progress', 'completed', 'rejected')" groups="mobile_repair_management.group_repair_manager,mobile_repair_management.group_repair_lead"/>
                    <button name="action_register_payment" string="Register Payment" type="object" class="btn-secondary" invisible="warranty or not invoice_id or payment_status == 'paid' or state in ('in_progress', 'completed', 'rejected')" groups="mobile_repair_management.group_repair_manager,mobile_repair_management.group_repair_accounting"/>
                    <button name="action_fix_missing_condemned_scope" string="Fix Condemned For" type="object" class="btn-secondary" groups="mobile_repair_management.group_repair_manager"/>
                    <button name="action_start_repair" string="Start Repair" type="object" class="btn-primary" invisible="state in ('in_progress', 'completed', 'rejected') or not team_id or (not warranty and (not invoice_id or payment_status != 'paid'))" groups="mobile_repair_management.group_repair_manager,mobile_repair_management.group_repair_lead,mobile_repair_management.group_repair_technician"/>
                    <button name="action_complete_repair" string="Complete Repair" type="object" class="btn-primary" invisible="state != 'in_progress'" groups="mobile_repair_management.group_repair_manager,mobile_repair_management.group_repair_lead,mobile_repair_management.group_repair_technician"/>
                    <button name="action_cancel_repair" string="Cancel" type="object" class="btn-secondary" invisible="state == 'completed'" groups="mobile_repair_management.group_repair_manager,mobile_repair_management.group_repair_lead,mobile_repair_management.group_repair_csr"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,requested,quotation,approved,in_progress,completed"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_picking" type="object" class="oe_stat_button" icon="fa-truck" invisible="not picking_id" groups="mobile_repair_management.group_repair_manager,mobile_repair_management.group_repair_lead,mobile_repair_management.group_repair_procurement">
                            <div class="o_stat_info">
                                <field name="picking_id" widget="statinfo" string="Picking"/>
                            </div>
                        </button>
                        <button name="action_view_invoice" type="object" class="oe_stat_button" icon="fa-money" invisible="not invoice_id" groups="mobile_repair_management.group_repair_manager,mobile_repair_management.group_repair_lead,mobile_repair_management.group_repair_csr,mobile_repair_management.group_repair_accounting">
                            <div class="o_stat_info">
                                <field name="invoice_id" widget="statinfo" string="Invoice"/>
                            </div>
                        </button>
                        <button name="action_view_task" type="object" class="oe_stat_button" icon="fa-tasks" invisible="not task_id" groups="mobile_repair_management.group_repair_manager,mobile_repair_management.group_repair_lead,mobile_repair_management.group_repair_technician">
                            <div class="o_stat_info">
                                <field name="task_id" widget="statinfo" string="Task"/>
                            </div>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" class="oe_inline"/>
                        </h1>
                        <h2>
                            <field name="customer_id" widget="many2one_avatar"/>
                        </h2>
                    </div>

                    <group col="2">
                        <group string="Customer &amp; Device">
                            <field name="customer_phone" widget="phone"/>
                            <field name="customer_email" widget="email"/>
                            <field name="brand_id"/>
                            <field name="series_id" domain="[('brand_id', '=', brand_id)]"/>
                            <field name="model_id" domain="[('series_id', '=', series_id)]"/>
                        </group>
                        <group string="Issue &amp; Warranty">
                            <field name="problem_description" placeholder="Describe the issue reported by the customer..."/>
                            <field name="warranty"/>
                            <field name="warranty_number" invisible="not warranty"/>
                            <field name="warranty_expiry_date" invisible="not warranty"/>
                            <field name="total_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Device Details">
                            <group col="2">
                                <group string="Identification">
                                    <field name="imei"/>
                                    <field name="serial_number"/>
                                    <field name="device_condition"/>
                                </group>
                                <group string="Inspection &amp; Delivery">
                                    <field name="inspection_date"/>
                                    <field name="inspection_type"/>
                                    <field name="delivery_type"/>
                                    <field name="expected_duration"/>
                                </group>
                            </group>
                            <group>
                                <field name="device_accessories" placeholder="Accessories received (charger, case, SIM tray, etc.)" colspan="4"/>
                            </group>
                            <group string="Customer Condemned Parts">
                                <field name="part_ids"
                                       domain="[('condition_status', '=', 'condemned'), ('condemned_scope', '=', 'customer')]"
                                       context="{'default_condition_status': 'condemned', 'default_condemned_scope': 'customer'}">
                                    <list editable="bottom">
                                        <field name="product_id"/>
                                        <field name="description" optional="hide"/>
                                        <field name="quantity"/>
                                        <field name="currency_id" invisible="1"/>
                                        <field name="unit_price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                        <field name="condemned_scope" optional="hide"/>
                                        <field name="condition_date"/>
                                        <field name="condition_reason"/>
                                        <field name="price_total" widget="monetary" options="{'currency_field': 'currency_id'}" sum="Total"/>
                                    </list>
                                </field>
                            </group>
                        </page>

                        <page string="Services">
                            <field name="service_ids">
                                <list editable="bottom">
                                    <field name="service_id"/>
                                    <field name="description" optional="hide"/>
                                    <field name="quantity"/>
                                    <field name="currency_id" invisible="1"/>
                                    <field name="price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="price_total" widget="monetary" options="{'currency_field': 'currency_id'}" sum="Total"/>
                                </list>
                            </field>
                            <group col="2">
                                <div/>
                                <group>
                                    <field name="service_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </group>
                            </group>
                        </page>

                        <page string="Parts">
                            <field name="part_ids" domain="[('condition_status', '!=', 'condemned')]">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="description" optional="hide"/>
                                    <field name="quantity"/>
                                    <field name="currency_id" invisible="1"/>
                                    <field name="unit_price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="stock_available" optional="hide"/>
                                    <field name="price_total" widget="monetary" options="{'currency_field': 'currency_id'}" sum="Total"/>
                                </list>
                            </field>
                            <group col="2">
                                <div/>
                                <group>
                                    <field name="part_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </group>
                            </group>
                        </page>

                        <page string="Workflow &amp; Team" groups="mobile_repair_management.group_repair_manager,mobile_repair_management.group_repair_lead,mobile_repair_management.group_repair_csr,mobile_repair_management.group_repair_accounting">
                            <group col="2">
                                <group string="Workflow">
                                    <field name="state" readonly="1"/>
                                    <field name="customer_approval"/>
                                    <field name="quotation_date" invisible="state != 'quotation'"/>
                                    <field name="quotation_valid_until" invisible="state != 'quotation'"/>
                                    <field name="invoice_status" readonly="1"/>
                                    <field name="payment_status" readonly="1"/>
                                </group>
                                <group string="Team">
                                    <field name="team_id"/>
                                    <field name="assigned_member_ids" widget="many2many_tags"/>
                                    <field name="start_date" readonly="1"/>
                                    <field name="completion_date" readonly="1"/>
                                </group>
                            </group>
                            <group col="2">
                                <group string="Totals">
                                    <field name="service_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="part_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="subtotal" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="total_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </group>
                            </group>
                        </page>

                        <page string="Task &amp; Work Log" groups="mobile_repair_management.group_repair_manager,mobile_repair_management.group_repair_lead,mobile_repair_management.group_repair_technician">
                            <group>
                                <field name="task_id" readonly="1"/>
                            </group>
                            <field name="timesheet_ids">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="user_id"/>
                                    <field name="duration"/>
                                    <field name="is_billable"/>
                                    <field name="description"/>
                                </list>
                            </field>
                        </page>

                        <page string="Warehouse Condemned Parts" groups="mobile_repair_management.group_repair_manager,mobile_repair_management.group_repair_lead,mobile_repair_management.group_repair_procurement">
                            <field name="part_ids"
                                   domain="[('condition_status', '=', 'condemned'), ('condemned_scope', '=', 'warehouse')]"
                                   context="{'default_condition_status': 'condemned', 'default_condemned_scope': 'warehouse'}">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="description" optional="hide"/>
                                    <field name="quantity"/>
                                    <field name="currency_id" invisible="1"/>
                                    <field name="unit_price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="condemned_scope" optional="hide"/>
                                    <field name="condition_date"/>
                                    <field name="condition_reason"/>
                                    <field name="price_total" widget="monetary" options="{'currency_field': 'currency_id'}" sum="Total"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- Job Card Search View -->
    <record id="view_job_card_search" model="ir.ui.view">
        <field name="name">job.card.search</field>
        <field name="model">job.card</field>
        <field name="arch" type="xml">
            <search string="Search Job Cards">
                <field name="name" string="Job Card No."/>
                <field name="customer_id"/>
                <field name="brand_id"/>
                <field name="model_id"/>
                <field name="state" filter_domain="[('state', '=', self)]"/>
                <field name="team_id"/>
                <field name="warranty"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Requested" name="requested" domain="[('state', '=', 'requested')]"/>
                <filter string="Quotation" name="quotation" domain="[('state', '=', 'quotation')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="In Progress" name="in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Completed" name="completed" domain="[('state', '=', 'completed')]"/>
                <filter string="Warranty Repairs" name="warranty" domain="[('warranty', '=', True)]"/>
                <filter string="Today" name="today" domain="[('create_date', '>=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="This Week" name="this_week" domain="[('create_date', '>=', (context_today() - datetime.timedelta(days=context_today().weekday())).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Brand" name="group_brand" context="{'group_by': 'brand_id'}"/>
                    <filter string="Team" name="group_team" context="{'group_by': 'team_id'}"/>
                    <filter string="Month" name="group_month" context="{'group_by': 'create_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Job Card Action -->
    <record id="action_job_card" model="ir.actions.act_window">
        <field name="name">Job Cards</field>
        <field name="res_model">job.card</field>
        <field name="view_mode">kanban,list,form,pivot,graph</field>
        <field name="search_view_id" ref="view_job_card_search"/>
        <field name="context">{'search_default_draft': 1}</field>
        <field name="groups_id" eval="[(6, 0, [
            ref('mobile_repair_management.group_repair_manager'),
            ref('mobile_repair_management.group_repair_lead'),
            ref('mobile_repair_management.group_repair_technician'),
            ref('mobile_repair_management.group_repair_csr'),
            ref('mobile_repair_management.group_repair_procurement'),
            ref('mobile_repair_management.group_repair_accounting'),
        ])]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first job card!
            </p>
        </field>
    </record>

    <!-- Condemned Parts Report (list + search) -->
    <record id="view_job_card_part_line_tree" model="ir.ui.view">
        <field name="name">job.card.part.line.list</field>
        <field name="model">job.card.part.line</field>
        <field name="arch" type="xml">
            <list string="Repair Parts" create="false" edit="false">
                <field name="job_card_id"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="condition_status"/>
                <field name="condemned_scope"/>
                <field name="condition_date"/>
                <field name="condition_reason"/>
                <field name="condemned_move_id"/>
                <field name="currency_id" invisible="1"/>
                <field name="unit_price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="price_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
            </list>
        </field>
    </record>

    <record id="view_job_card_part_line_search" model="ir.ui.view">
        <field name="name">job.card.part.line.search</field>
        <field name="model">job.card.part.line</field>
        <field name="arch" type="xml">
            <search string="Search Repair Parts">
                <field name="job_card_id"/>
                <field name="product_id"/>
                <field name="condition_status"/>
                <field name="condemned_scope"/>
                <filter string="Condemned" name="condemned" domain="[('condition_status', '=', 'condemned')]"/>
                <filter string="Customer Condemned" name="condemned_customer" domain="[('condition_status', '=', 'condemned'), ('condemned_scope', '=', 'customer')]"/>
                <filter string="Warehouse Condemned" name="condemned_warehouse" domain="[('condition_status', '=', 'condemned'), ('condemned_scope', '=', 'warehouse')]"/>
                <group expand="0" string="Group By">
                    <filter string="Job Card" name="group_job" context="{'group_by': 'job_card_id'}"/>
                    <filter string="Condition" name="group_condition" context="{'group_by': 'condition_status'}"/>
                    <filter string="Scope" name="group_scope" context="{'group_by': 'condemned_scope'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'condition_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_condemned_parts" model="ir.actions.act_window">
        <field name="name">Damaged / Condemned Parts</field>
        <field name="res_model">job.card.part.line</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="domain">[('condition_status', '=', 'condemned')]</field>
        <field name="search_view_id" ref="view_job_card_part_line_search"/>
        <field name="groups_id" eval="[(6, 0, [
            ref('mobile_repair_management.group_repair_manager'),
            ref('mobile_repair_management.group_repair_lead'),
            ref('mobile_repair_management.group_repair_procurement'),
        ])]"/>
    </record>
</odoo>