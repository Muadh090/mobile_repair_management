<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Mobile Repair Management — Role Hierarchy
        ==========================================
        Uses Odoo's category-based selection group pattern so each user
        gets exactly ONE role.  Higher roles automatically inherit all
        permissions of lower roles.

        User          – CSR / front-desk: create job cards, manage quotations
        Technician    – implies User: repair work, timesheets, parts
        Manager       – implies Technician: full control, configuration,
                        invoicing, teams, reports, condemned parts
    -->

    <!-- Module category (shown in Settings › Users) -->
    <record id="module_category_repair" model="ir.module.category">
        <field name="name">Mobile Repair</field>
        <field name="description">Mobile device repair management roles</field>
        <field name="sequence">30</field>
    </record>

    <!-- Tier 1 — User (CSR / front-desk) -->
    <record id="group_repair_user" model="res.groups">
        <field name="name">User</field>
        <field name="comment">Create and manage job cards, handle quotations and customer approvals.</field>
        <field name="category_id" ref="module_category_repair"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Tier 2 — Technician (implies User) -->
    <record id="group_repair_technician" model="res.groups">
        <field name="name">Technician</field>
        <field name="comment">Perform repairs, log timesheets, manage parts. Inherits all User permissions.</field>
        <field name="category_id" ref="module_category_repair"/>
        <field name="implied_ids" eval="[(4, ref('group_repair_user'))]"/>
    </record>

    <!-- Tier 3 — Manager (implies Technician → User) -->
    <record id="group_repair_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="comment">Full access: configuration, teams, invoicing, reports, condemned parts. Inherits all lower roles.</field>
        <field name="category_id" ref="module_category_repair"/>
        <field name="implied_ids" eval="[(4, ref('group_repair_technician'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>