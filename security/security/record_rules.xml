<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================ -->
    <!--  Job Card record rules                                       -->
    <!--  User: see all cards, create/write, no delete                -->
    <!--  Technician: inherits User (sees all), can also write        -->
    <!--  Manager: full access (inherits Technician → User)           -->
    <!-- ============================================================ -->
    <record id="rule_job_card_user" model="ir.rule">
        <field name="name">Job Card: User – Read / Create / Write</field>
        <field name="model_id" ref="model_job_card"/>
        <field name="groups" eval="[(4, ref('mobile_repair_management.group_repair_user'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_job_card_manager" model="ir.rule">
        <field name="name">Job Card: Manager – Full Access</field>
        <field name="model_id" ref="model_job_card"/>
        <field name="groups" eval="[(4, ref('mobile_repair_management.group_repair_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <!-- ============================================================ -->
    <!--  Part Line record rules                                      -->
    <!-- ============================================================ -->
    <record id="rule_job_card_part_line_user" model="ir.rule">
        <field name="name">Part Line: User – Read / Create / Write</field>
        <field name="model_id" ref="model_job_card_part_line"/>
        <field name="groups" eval="[(4, ref('mobile_repair_management.group_repair_user'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_job_card_part_line_manager" model="ir.rule">
        <field name="name">Part Line: Manager – Full Access</field>
        <field name="model_id" ref="model_job_card_part_line"/>
        <field name="groups" eval="[(4, ref('mobile_repair_management.group_repair_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <!-- ============================================================ -->
    <!--  Service Line record rules                                   -->
    <!-- ============================================================ -->
    <record id="rule_job_card_service_line_user" model="ir.rule">
        <field name="name">Service Line: User – Read / Create / Write</field>
        <field name="model_id" ref="model_job_card_service_line"/>
        <field name="groups" eval="[(4, ref('mobile_repair_management.group_repair_user'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_job_card_service_line_manager" model="ir.rule">
        <field name="name">Service Line: Manager – Full Access</field>
        <field name="model_id" ref="model_job_card_service_line"/>
        <field name="groups" eval="[(4, ref('mobile_repair_management.group_repair_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <!-- ============================================================ -->
    <!--  Timesheet record rules                                      -->
    <!--  Technician: own timesheets only, no delete                  -->
    <!--  Manager: full access to all timesheets                      -->
    <!-- ============================================================ -->
    <record id="rule_timesheet_technician" model="ir.rule">
        <field name="name">Timesheet: Technician – Own Only</field>
        <field name="model_id" ref="model_repair_timesheet"/>
        <field name="groups" eval="[(4, ref('mobile_repair_management.group_repair_technician'))]"/>
        <field name="domain_force">['|', ('user_id', '=', user.id), ('job_card_id.assigned_member_ids', 'in', user.id)]</field>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_timesheet_manager" model="ir.rule">
        <field name="name">Timesheet: Manager – Full Access</field>
        <field name="model_id" ref="model_repair_timesheet"/>
        <field name="groups" eval="[(4, ref('mobile_repair_management.group_repair_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>
